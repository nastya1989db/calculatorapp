<?xml version ="1.0"?>
<project basedir="." default="test" name="calculator_3">
	<description>A simple Java project
	</description>
	<property name="srcDir" location="src"/>
	<property name="buildDir" location="build"/>
	<property name="jarDir" location="../other/jarAll"/>
	<property name="reportDir" location="report"/>
	<property name="nameJar" value="CalculatorMinus.jar"/>
	<property name="libDir" location="lib"/>

    	<path id="classpath">
        	<fileset dir="${libDir}" includes="**/*.jar"/>
        	<pathelement location="${buildDir}"/>
    	</path>

	<target name="clean">
        	<delete dir="${buildDir}"/>
		<delete dir="${jarDir}/${nameJar}"/>
    		<delete dir="${reportDir}"/>

	</target>

	<target name="init" depends="clean">
		<mkdir dir="${buildDir}"/>
		<mkdir dir="${jarDir}"/> 
		<mkdir dir="${reportDir}"/>

	</target>

	<target name="compile" depends="init">
		<javac srcdir="${srcDir}" destdir="${buildDir}" classpathref="classpath" fork="true">
		</javac>           
	</target>

	<target name="jar" depends="compile">
		<jar destfile="${jarDir}/${nameJar}" basedir="${buildDir}">
    			<manifest>
            			<!--attribute name="Built-by" value="${user.name}"/-->
            			<attribute name="Main-Class" value="CalculatorMinus"/>
    			</manifest>
    		</jar>
	</target>
	<target name="test" depends="jar" >
        	<junit printsummary="yes" haltonfailure="no">
            		<formatter type="xml" />
            		<formatter type="plain" />
            		<batchtest fork="yes" todir="${reportDir}">
                		<fileset dir="${srcDir}">
               				<include name="**/*CalculatorTest3*.java" />
               			</fileset>
            		</batchtest>
            		<classpath refid="classpath"/>
        	</junit>
    	</target>
</project>
